generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  EXCHANGE
  REFERRAL_COMMISSION
  WITHDRAWAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REJECTED
}

model User {
  id            String         @id @default(uuid())
  readableId    BigInt         @unique @default(autoincrement())
  email         String         @unique
  firstName     String?
  lastName      String?
  role          Role           @default(USER)
  status        UserStatus     @default(PENDING_APPROVAL)
  balance       Float          @default(0)
  passcode      String?        // 6 digit passcode for authorization
  referralCode  String?        @unique
  referredBy    User?          @relation("UserReferrals", fields: [referredById], references: [id])
  referredById  String?
  referrals     User[]         @relation("UserReferrals")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  transactions  Transaction[]
  relatedTransactions Transaction[] @relation("RelatedUserTransactions")
  otps          Otp[]
  bankAccounts  BankAccount[]
  walletAssignments WalletAssignment[]
  notifications Notification[]
  deviceTokens  DeviceToken[]
}

model Transaction {
  id             String            @id @default(uuid())
  readableId     BigInt            @unique @default(autoincrement())
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  type           TransactionType
  amount         Float
  status         TransactionStatus @default(PENDING)
  fee            Float?            // Fee charged for withdrawal
  bankDetails    String?           // Stores E2EE encrypted JSON string
  conversionRate Float?            // Rate used at time of transaction
  utr            String?           // Unique Transaction Reference
  relatedUserId  String?           // Used for referral commissions to track source user
  relatedUser    User?             @relation("RelatedUserTransactions", fields: [relatedUserId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  logs           TransactionLog[]
}

model TransactionLog {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  status        TransactionStatus
  note          String?
  actor         String      // email of who triggered this (system / admin email)
  createdAt     DateTime    @default(now())

  @@index([transactionId])
}

model Otp {
  id            String    @id @default(uuid())
  email         String
  code          String
  expiresAt     DateTime
  user          User?     @relation(fields: [email], references: [email])
  createdAt     DateTime  @default(now())

  @@index([email])
}

model AdminPublicKey {
  id            String    @id @default(uuid())
  publicKey     String    @db.Text
  createdAt     DateTime  @default(now())
}

model GlobalSettings {
  id               String   @id @default("global_settings")
  usdtToInrRate    Float?
  withdrawalFee    Float?   @default(0)
  updatedAt        DateTime @updatedAt
}

model GlobalWallet {
  id        String   @id @default(uuid())
  name      String?
  address   String   @unique
  network   String   @default("TRC20")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assignments WalletAssignment[]
}

model ConversionRateHistory {
  id         String   @id @default(uuid())
  rate       Float
  adminEmail String
  createdAt  DateTime @default(now())
}

model WithdrawalFeeHistory {
  id         String   @id @default(uuid())
  fee        Float
  adminEmail String
  createdAt  DateTime @default(now())
}

model BankAccount {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String   // Beneficiary Name
  bankName    String
  accountNo   String
  ifsc        String
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs        BankAccountLog[]

  @@index([userId])
}

model BankAccountLog {
  id            String      @id @default(uuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  action        String      // CREATE, UPDATE, DELETE
  changes       String?     // JSON of what changed
  createdAt     DateTime    @default(now())

  @@index([bankAccountId])
}

model WalletAssignment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  walletId  String
  wallet    GlobalWallet @relation(fields: [walletId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  body        String
  type        String   // e.g., TRANSACTION_NEW, TRANSACTION_STATUS, QR_ASSIGNMENT
  relatedId   String?  // transactionId or walletId
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

enum NewsStatus {
  PUBLISHED
  ARCHIVED
}

model News {
  id          String     @id @default(uuid())
  title       String
  description String
  link        String?
  status      NewsStatus @default(PUBLISHED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

